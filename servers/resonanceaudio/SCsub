# Generate .gen.h from Slang-compiled GLSL shaders.
import os


def glsl_to_gen_h(target, source, env):
    src_path = str(source[0])
    dst_path = str(target[0])
    var_name = os.path.basename(src_path).replace(".", "_")
    with open(src_path, "r") as f:
        glsl = f.read()
    with open(dst_path, "w") as f:
        f.write("// Generated from %s - do not edit.\n" % os.path.basename(src_path))
        f.write('static const char %s[] = R"GLSL(\n' % var_name)
        f.write(glsl)
        f.write(')GLSL";\n')
    return 0


env_resonance.Append(
    BUILDERS={
        "GlslGenH": env_resonance.Builder(
            action=env_resonance.Action(glsl_to_gen_h, "Generating $TARGET from $SOURCE"),
            suffix=".gen.h",
            src_suffix=".glsl",
        )
    }
)
env_resonance.GlslGenH("shaders/reverb_bake.glsl.gen.h", "shaders/reverb_bake.glsl")


def spv_to_gen_h(target, source, env):
    src_path = str(source[0])
    dst_path = str(target[0])
    var_name = os.path.basename(src_path).replace(".", "_")
    with open(src_path, "rb") as f:
        data = f.read()
    with open(dst_path, "w") as f:
        f.write("// Generated from %s - do not edit.\n" % os.path.basename(src_path))
        f.write("static const unsigned char %s[] = {\n" % var_name)
        for i in range(0, len(data), 16):
            chunk = data[i : i + 16]
            f.write("\t" + ", ".join("0x%02x" % b for b in chunk) + ",\n")
        f.write("};\n")
        f.write("static const unsigned int %s_size = %d;\n" % (var_name, len(data)))
    return 0


env_resonance.Append(
    BUILDERS={
        "SpvGenH": env_resonance.Builder(
            action=env_resonance.Action(spv_to_gen_h, "Generating $TARGET from $SOURCE"),
            suffix=".gen.h",
            src_suffix=".spv",
        )
    }
)
env_resonance.SpvGenH("shaders/reverb_bake.spv.gen.h", "shaders/reverb_bake.spv")

